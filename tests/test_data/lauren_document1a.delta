[{"insert": "RULES OF PROCEDURE", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n", "attributes": {"align": null}}, {"insert": "C", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "HAPTER I.", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Definitions.", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n"}, {"insert": "1. These rules shall be called the Constituent Assembly Rules. They shall come into force at once.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "2. In these rules, unless the context otherwise requires\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) \"Assembly\" means the Constituent Assembly of India;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) \"Chairman\" means the person who for the time being presides over the Assembly or any of its Committees;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(c) \"Member\" means a member of the Assembly;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(cc) ", "attributes": {"background": "transparent"}}, {"insert": "\u00a0\u2018Minister\u2019 means a Member of the Council of Ministers of the Governor-General of India;\n"}, {"insert": "(d) \"President\" means the person el", "attributes": {"background": "transparent"}}, {"insert": "ect"}, {"insert": "ed by the Assembly at its preliminary session as the Chairman under the provisions of the Statement and his successors in office.", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(e", "attributes": {"background": "transparent"}}, {"insert": ")"}, {"insert": " \"Secretary\" means the Secretary of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(f", "attributes": {"background": "transparent"}}, {"insert": ")"}, {"insert": " \"Statement\" means the Statement of the Cabinet Mission to India and H.E. the Viceroy dated May 16, 1946.", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "C", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "HAPTER", "attributes": {"background": "transparent"}}, {"insert": " II", "attributes": {"italic": null, "background": "transparent"}}, {"insert": ".", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Ad", "attributes": {"background": "transparent", "italic": true}}, {"insert": "m", "attributes": {"italic": true}}, {"insert": "ission of Members and Vacation of Seats", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n\n", "attributes": {"align": "center"}}, {"insert": "3.", "attributes": {"background": "transparent"}}, {"insert": " "}, {"insert": "No member shall take his seat or vote in the Assembly until he has signed his name in the Register kept for the purpose at a meeting of the Assembly or, if the Assembly is not in session, in the presence of the President.", "attributes": {"background": "transparent"}}, {"insert": "\n\nProvided that every Minister who is not a Member of the Assembly shall have the right to speak in and otherwise to take part in the proceedings of the Assembly and any Committee thereof of which he may be named a member, but shall not be entitled to vote"}, {"insert": ".", "attributes": {"background": null}}, {"insert": "\n\n"}, {"insert": "4", "attributes": {"background": "transparent"}}, {"insert": ". "}, {"insert": "(1) A member may resign his office by writing under his hand addressed to the President.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(", "attributes": {"background": "transparent"}}, {"insert": "2)"}, {"insert": " On the acceptance of the resignation by the President the seat shall become vacant.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "5. (1) When a vacancy occurs by reason of death, resignation or otherwise in the office of a member of the Assembly, the President shall notify the vacancy and call upon the constituency concerned to elect a person for the purpose of filling the vacancy.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) Upon the occurrence of the vacancy, the President shall ordinarily make a request in writing to the Speaker of the Provincial Legislative Assembly concerned, or, as the case may be,", "attributes": {"background": "transparent"}}, {"insert": " the ", "attributes": {"background": null}}, {"insert": "President of the Coorg Legislative Council, for the election of a person, for the purpose of filling the vacancy as soon as may reasonably be practicable.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) Where the vacancy is in the office of a member elected by a Provincial Legislative Assembly, the seat shall be filled by election according to the principle of proportional representation with the single transferable vote by the members of the same community whether General, Muslim or Sikh, in the Provincial Legislative Assembly, as had elected him.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) A candidate for a vacancy shall be such as could be elected by the constituency concerned under the Statement.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(5) Only an Indian, that is to say, a person domiciled in any part of India ", "attributes": {"background": "transparent"}}, {"insert": "which is participating or entitled to participate in this Assembly"}, {"insert": ", may be nominated for election as a member of the Constituent Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(6) As soon as may be after the receipt of the request mentioned in sub-rule (", "attributes": {"background": null}}, {"insert": "2)"}, {"insert": " the Speaker of the Provincial Legislative Assembly concerned", "attributes": {"background": null}}, {"insert": "\u2014\n\n(a)"}, {"insert": " shall appoint by suitable notification", "attributes": {"background": null}}, {"insert": " a person to be the Returning Officer for the election and may also in like manner appoint any person who may, subject to the control of the Returning Officer, perform all or any of the functions of the Returning officer at any such election, and\n\n"}, {"insert": "(", "attributes": {"background": null}}, {"insert": "b) sh"}, {"insert": "a", "attributes": {"background": null}}, {"insert": "ll also appoint by suitable notification\u2014\n\n(i"}, {"insert": ") a date, not later than fifteen days after the date of notification for the nomination of candidates;", "attributes": {"background": null}}, {"insert": "\n"}, {"insert": "(", "attributes": {"background": null}}, {"insert": "ii"}, {"insert": ") a further date, not later than the third day after the first", "attributes": {"background": null}}, {"insert": "-"}, {"insert": "mentioned date, for the scrutiny of nominations;", "attributes": {"background": null}}, {"insert": "\n"}, {"insert": "(", "attributes": {"background": null}}, {"insert": "iii"}, {"insert": ") a further date, not later than two days after scrutiny", "attributes": {"background": null}}, {"insert": ","}, {"insert": " for withdrawal of his candidature by a candidate; and", "attributes": {"background": null}}, {"insert": "\n"}, {"insert": "(", "attributes": {"background": null}}, {"insert": "iv"}, {"insert": ") a further date", "attributes": {"background": null}}, {"insert": ","}, {"insert": " not later than twenty", "attributes": {"background": null}}, {"insert": " "}, {"insert": "one days from the date fixed for withdrawal on which a poll shall if necessary, be taken.", "attributes": {"background": null}}, {"insert": "\n\n"}, {"insert": "(", "attributes": {"background": null}}, {"insert": "6)A. The Speaker of the Provincial Legislative Assembly concerned shall, if a poll is taken, by suitable notification fix the hour at which the poll shall commence and the hour at which it shall close on the date fixed under sub-clause (iv) of clause (b) of sub-rule (6) and the place at which the poll shall be taken.\n\n"}, {"insert": "(7) The votes shall be given by ballot and in person:", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "Provided that when the Provincial Legislative Assembly is not in session, votes may, at the option of the voter, be given in person or by registered post, provided further that no votes shall be given by proxy.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(8) After the votes are duly counted, the result of the election shall be declared and reported to the President.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(9) Save as otherwise provided in these Rules, the elections to the Constituent Assembly, shall be held, ", "attributes": {"background": "transparent"}}, {"insert": "mutatis mutandis", "attributes": {"italic": true, "background": "transparent"}}, {"insert": ", in accordance with the rules and regulations for the time being in force in regard to elections held by the Provincial Legislative Assembly, and, where no such rules and regulations exist, in accordance with the standing orders that may be made in this behalf by the President of the Constituent Assembly, ", "attributes": {"background": "transparent"}}, {"insert": "where any such rules or regulations exist, it shall be competent for the Speaker of the Provincial Legislative Assembly concerned to make, with the previous approval of the President, such modifications therein as may be necessary for the purposes of this sub-rule"}, {"insert": ".", "attributes": {"background": null}}, {"insert": "\n\n"}, {"insert": "(10) The foregoing rules shall apply in relation to Coorg, subject to the following modifications, namely,\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) that for the \"Provincial Legislative Assembly\" there shall be substituted \"the Coorg Legislative Council\" and for the \"Speaker of the Provincial Legislative Assembly\" there shall be substituted the \"President of the Coorg Legislative Council\", and", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) that instead of a section of the Provincial Legislature taking part in the election, the non-official members of the Coorg Legislative Council shall take part in it.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(11) ", "attributes": {"background": null}}, {"insert": "The foregoing rules shall apply in relation to Delhi and Ajmer-Merwara subject to th"}, {"insert": "e ", "attributes": {"background": null}}, {"insert": "follow"}, {"insert": "in", "attributes": {"background": null}}, {"insert": "g modifications, namely:\n\n(a) that"}, {"insert": " for the ", "attributes": {"background": null}}, {"insert": "\u2018the Provincial Legislative Assembly\u2019 there shall be substituted \u2018the"}, {"insert": " Delhi ", "attributes": {"background": null}}, {"insert": "Advis"}, {"insert": "or", "attributes": {"background": null}}, {"insert": "y Council or the"}, {"insert": " Ajmer-Merwara ", "attributes": {"background": null}}, {"insert": "Adv"}, {"insert": "i", "attributes": {"background": null}}, {"insert": "sory Cou"}, {"insert": "n", "attributes": {"background": null}}, {"insert": "cil, as"}, {"insert": " the ", "attributes": {"background": null}}, {"insert": "case may be; a"}, {"insert": "nd", "attributes": {"background": null}}, {"insert": " for the \u2018the Speaker of the Prov"}, {"insert": "in", "attributes": {"background": null}}, {"insert": "cial"}, {"insert": " Legislative Assembly", "attributes": {"background": null}}, {"insert": "\u2019 there"}, {"insert": " shall be ", "attributes": {"background": null}}, {"insert": "substituted \u2018the Chairman of the"}, {"insert": " Delhi or Ajmer-", "attributes": {"background": null}}, {"insert": " "}, {"insert": "Merwara", "attributes": {"background": null}}, {"insert": " Advisory Council"}, {"insert": " as the case may be", "attributes": {"background": null}}, {"insert": "\u2019.\n\n(b) that instead of"}, {"insert": " a", "attributes": {"background": null}}, {"insert": " sectio"}, {"insert": "n o", "attributes": {"background": null}}, {"insert": "f "}, {"insert": "the", "attributes": {"background": null}}, {"insert": " Provincial Legislature taking part"}, {"insert": " in the ", "attributes": {"background": null}}, {"insert": "election, the non-official members of"}, {"insert": " the", "attributes": {"background": null}}, {"insert": " Delhi or the Ajmer-Merwara Advisory Council shall take part in i"}, {"insert": "t.", "attributes": {"background": null}}, {"insert": "\n\n(12) If any vacancy occurs by reason of death, resignation, or otherwise in the office of a member representing Delhi or Ajmer-Merwara in the Constituent Assembly, the President shall notify the vacancy and shall call upon the Chief Commissioner of Delhi or Ajmer-Merwara as the case may be, to take steps to hold, a bye-election to fill the vacancy. The bye-elections shall be held, as nearly as may be, in accordance with the procedure prescribed by the Legislative Assembly Electoral Rules, as in force on August 1, 1947, for the election of a member to represent Delhi or, as the case may be, the Ajmer-Merwara constituency of the Indian Legislative Assembly\n\n5-A. When a vacancy occurs by reason of death, resignation or otherwise in the office of a member of the Assembly representing an Indian State, the President shall notify the vacancy and make a request in writing to the Ruler of the Indian State concerned to proceed to fill the vacancy, as soon as may reasonably be practicable, by election or nomination, as the case may be. \n\nProvided that where the seat was filled previously by nomination, the Ruler may fill the vacancy by election.\n\n5-B. In the case of a vacancy in the office of a member of the Assembly representing more than one Indian State, the President shall notify the vacancy and make a request in writing to the Rulers of the Indian States concerned to, proceed to fill the vacancy, as soon as may reasonably be practicable, by the same method as was applicable to the case of the outgoing member when he was chosen as a member of the Assembly.\n\n"}, {"insert": "C", "attributes": {"italic": null}}, {"insert": "HAPTER III.", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "The President.", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n"}, {"insert": "6. (1) The President of the Assembly s", "attributes": {"background": "transparent"}}, {"insert": "ha", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "ll be elected by the Assembly from among its members.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The President shall cease to hold office as such if he ceases to be a member of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) The President may resign office by writing under his hand addressed to the Secretary for communication to the Assembly. If the Assembly is in session, the resignation shall be read out to the members; if the Assembly is not in session, it shall be ", "attributes": {"background": "transparent"}}, {"insert": "p", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "ublished in the ", "attributes": {"background": "transparent"}}, {"insert": "Gazette of India", "attributes": {"background": "transparent", "italic": true}}, {"insert": "; upon being so ", "attributes": {"background": "transparent"}}, {"insert": "r", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "ead out or published, as the case may be, it shall become effective.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "7. (1) When, owing to a vacancy in the office of President of the Assembly, the election of President becomes necessary, one of the Vice-Presidents appointed in this behalf by the Steering Committee, shall fix a date for the holding of the election and the Secretary shall send to every member notice of the date so fixed.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) At any time before noon on the day preceding the date so fixed, any member may nominate another member for election by delivering to the Secretary a nomination paper signed by himself as proposer and by a third member as seconder and stating\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) the name of the member nominated, and", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) that the proposer has ascertained that such member is willing to serve as president if elected.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) Any member who has been nominated may withdraw his candidature at any time before the Assembly proceeds to hold the election.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) On the date fixed for an election, the Vice-President shall read out to the Assembly the names of the members who have been duly nominated and have not withdrawn their candidature together with those of their proposers and seconders, and, if there is only one much member, the Assembly shall proceed to elect the President by ballot.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(5) Where there are only two candidates for election, the candidate who obtains at the ballot the larger number of votes shall be declared elected.", "attributes": {"background": "transparent"}}, {"insert": " I", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "f they obtain an equal number of votes, the election shall be by the drawing of lots.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": " (6) Where more than two candidates have been nominated and at the first ballot no candidate obtains more votes that the aggregate votes obtained by the other candidates, the candidate who has obtained the smallest number of votes shall be excluded from the election, and balloting shall proceed, the candidate obtaining the smallest number of votes at each ballot being excluded from the election, until one candidate obtains more votes that the remaining candidate or than the aggregate votes of the remaining candidates, as the case may be, and such candidate shall be declared elected.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(7) Where at any ballot any of three or more candidates obtain an equal number of votes and one of them has to be excluded from the election under sub-rule (6) the determination, as between the candidates whose votes are equal, of the candidate who is to be excluded shall be by the drawing of lots.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "8. (1) The deliberations of the Assembly shall be presided over by the President, when he is present.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The President shall be the guardian of the privileges of the Assembly, its spokesman and representative and its highest executive authority.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "9. The President may, subject to such conditions as he may prescribe, delegate to a Vice-President such of his powers and duties as he may think fit.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "CHAPTER IV.", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Vice-Presidents.", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n"}, {"insert": "10. The Assembly shall have two Vice-Presidents who shall be elected by the Assembly from amongst its members in such manner as the President may prescribe.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "11. The President shall fix the date and time for the nomination and election of each of the two Vice-Presidents to be elected under rule 11.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "12. (1) A Vice-President shall cease to hold office as such if he ceases to be a member of the Assembly. A Vice-President may resign office by writing under his hand addressed to the President, and, on acceptance thereof by the President, the resignation shall become effective.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) Any vacancy in the office of a Vice-President of the Assembly shall be filled by an election by the Assembly from among its members at such time and in such manner as the President may prescribe.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "13. In the absence of the President, such Vice-President as the President may determine shall preside over the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "14. If the President is absent and there is no Vice-President present to preside over the Assembly, the Assembly may choose any member to perform the duties of the Chairman.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "CHAPTER V.", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Office of the Constituent Assembly.", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n\n", "attributes": {"align": "center"}}, {"insert": "15. (1) The President shall be the head of the office of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n", "attributes": {"align": null}}, {"insert": "(2) The Office shall consist of two branches, an Advisory Branch and an Administrative Branch.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) There shall be a Constitutional Adviser, to be appointed by the President, who shall be the head the Advisory Branch.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) There shall be a full-time Secretary, to be appointed by the President, who shall be the head of the Administrative Branch.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(5) There shall be under the Constitutional Adviser and the Secretary respectively such other officers and establishments as the President may, on the advice of the Staff and Finance Committee, determine.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(7) The President may, in consultation with the Government of any Governor\u2019s Province, appoint a Secretary for the Province, who shall rank as a Deputy Secretary in the Office of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(8) Any member of the Assembly who becomes the Secretary of a Deputy Secretary under this rule shall thereupon be deemed to have vacated his office as member.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(9) The President shall exercise in respect of the Office of the Assembly all powers of appointment, control and discipline, provided that he may delegate to any officer such of these powers as he thinks fit and subject to such conditions as he may prescribe.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "16. It shall be among the duties of the Secretary\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) to administer the funds placed at the disposal of the Assembly in accordance with the provisions in the budget accepted by the Assembly;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) to keep and maintain the records relating to the business of the Assembly; and", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(c) to make arrangements for meetings of the Assembly and its Committees.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "CHAPTER VI.", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Business of the Assembly.", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n"}, {"insert": "17 (1) The business of the Assembly means the business conducted\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(", "attributes": {"background": "transparent"}}, {"insert": "i)"}, {"insert": " in the Assembly itself;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(i", "attributes": {"background": "transparent"}}, {"insert": "i"}, {"insert": ") in the Committee of the whole Assembly;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(i", "attributes": {"background": "transparent"}}, {"insert": "v"}, {"insert": ") in the Advisory Committee referred to in paragraph 20 of the Statement;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(v", "attributes": {"background": "transparent"}}, {"insert": ")"}, {"insert": " in the Steering Committee;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(v", "attributes": {"background": "transparent"}}, {"insert": "i"}, {"insert": ") in the Staff and Finance Committee;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(v", "attributes": {"background": "transparent"}}, {"insert": "i"}, {"insert": "i) in the Credentials Committee;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(v", "attributes": {"background": "transparent"}}, {"insert": "iii) in the House Committee; and\n(ix"}, {"insert": ")", "attributes": {"background": "transparent"}}, {"insert": " i"}, {"insert": "n such other committees or sub-committees as may be set up by the Assembly or the Advisory Committee or other committees.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(", "attributes": {"background": "transparent"}}, {"insert": "2)"}, {"insert": " The business of the Assembly shall be conducted in New Delhi unless the Assembly resolves otherwise.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(", "attributes": {"background": "transparent"}}, {"insert": "3)"}, {"insert": " The conduct of the business of the Assembly and the procedure thereof shall be regulated by the rules and standing orders and the resolutions of the Assembly and by the rulings given from time to time by the Chairman.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "18. The Assembly shall not be dissolved except by a resolution assented to by at least two-thirds of the total number of members of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "19. The Assembly shall sit on such dates as the President, having regard to the state of business\u00a0of the Assembly, may from time to time direct:", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "P", "attributes": {"background": "transparent"}}, {"insert": "ro"}, {"insert": "vided that the President shall not adjourn the session for more than three days at a time except with the consent of the Assembly:", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "P", "attributes": {"background": "transparent"}}, {"insert": "ro"}, {"insert": "vided further that the Chairman may adjourn the session to the next working day.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "20. The Assembly may resolve itself into a Committee of the whole Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "21. Meetings of the Assembly shall commence at 11 A.M., except as otherwise resolved by the Assembly or directed by the Chairman.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "2", "attributes": {"background": null}}, {"insert": "2. (1) The presence of at least one-third of the whole number of members shall be necessary to constitute a meeting of the Assembly or any of its committees.\n\n(2) If the Chairman, on a count being demanded by a member at any time during a meeting, ascertains that one-third of the whole number of members are not present, he shall adjourn the Assembly or the committee, as the case may be, for fifteen minutes, and if on a fresh count being taken after that period it is found that there is still no quorum, he shall adjourn the Assembly or the committee as the case may be, till the next day on which it ordinary sits.\n\n"}, {"insert": "23. (1) A list of business for the day shall be prepared by the Secretary and a copy thereof shall be supplied for the use of every member before the commencement of the business of the day. The business thus prepared shall be called the \u201cOr", "attributes": {"background": "transparent"}}, {"insert": "d"}, {"insert": "ers of the Day\u201d.\u00a0", "attributes": {"background": "transparent"}}, {"insert": "\n\n(2)"}, {"insert": " Save as otherwise provided in these rules, no business, not included in the Orders of the Day, shall be transacted at any meeting without the leave of the Chairman.", "attributes": {"background": "transparent"}}, {"insert": "\n\n24."}, {"insert": " The business of the Assembly shall be brought before it or its committees by means of\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(", "attributes": {"background": "transparent"}}, {"insert": "a)"}, {"insert": " a motion;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b", "attributes": {"background": "transparent"}}, {"insert": ")"}, {"insert": " a report of a committee;\u00a0", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(c", "attributes": {"background": "transparent"}}, {"insert": ")"}, {"insert": " an amendment to a motion or an amendment to an amendment.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "25. (1) Unless otherwise directed by the Chairman, notice of every motion, accompanied by a copy of the motion shall be given at least three clear days before the day on which the motion is to be moved i", "attributes": {"background": "transparent"}}, {"insert": "n t"}, {"insert": "he Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) Every notice required by these rules shall be given in writing addressed to the Secretary and signed by the member giving notice and shall be left at the Notice Office, which shall be open for the purpose between the hours of 11 A", "attributes": {"background": "transparent"}}, {"insert": ".M"}, {"insert": ". and 5 P.M.", "attributes": {"background": "transparent"}}, {"insert": " ex"}, {"insert": "cept on Sundays and other public holidays.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) Notices left when the office is closed shall be treated as given on the", "attributes": {"background": "transparent"}}, {"insert": " ne"}, {"insert": "xt open day.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) Where three clear days\u2019 notice of a motion has been given, the Secretary shall send a copy of the motion to the members at least two clear days before the day on which it is to be moved; and in other cases, he shall send a copy to them as soon as possible after notice has", "attributes": {"background": "transparent"}}, {"insert": " be"}, {"insert": "en received.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(5) No notice sha", "attributes": {"background": "transparent"}}, {"insert": "ll "}, {"insert": "be required\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) for a motion for an adjournment o", "attributes": {"background": "transparent"}}, {"insert": "f "}, {"insert": "the Assembly;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) for a motion for adjournment of the consideration of the motion which is un", "attributes": {"background": "transparent"}}, {"insert": "de"}, {"insert": "r discussion;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(c) for a motion for reference back ", "attributes": {"background": "transparent"}}, {"insert": "to"}, {"insert": " a committee;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(d) for a motion that the Assembly do resolve itself into committee o", "attributes": {"background": "transparent"}}, {"insert": "f "}, {"insert": "the whole; or", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(e) for a motion which, in the opinion of the Chairman, is of urgent and vi", "attributes": {"background": "transparent"}}, {"insert": "tal"}, {"insert": " importance.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "26. There shall be no motion for an adjournment of the Assembly for the purpose of discussing any matter not included in the Orders of the Day, or not connected with the work of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "27. The members shall sit in such order as the President may direct.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "28. A member desiring to make any observation on any matter before the Assembly shall only speak when called upon to do so, b", "attributes": {"background": "transparent"}}, {"insert": "y"}, {"insert": ", t", "attributes": {"background": "transparent"}}, {"insert": "h"}, {"insert": "e Chairman and shall rise when he speaks, except as permitted by the Chairman. If at any time, the Chairman rises, the member shall take his seat and cease speaking.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "29. (1) In this Assembly, business shall be transacted in Hindustani (Hindi and Urdu) or English, provided that the Chairman may permit any member who cannot adequately express himself in either language to address the Assembly in his mother tongue. The Chairman will make arrangements for giving the Assembly, whenever he thinks fit, a summary of the speech in a language other than that used by the member and such summary shall be included in the record of the proceedings of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The official records of the proceedings of the Assembly shall be kept in Hindustani (both Hindi and Urdu) and English.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "30. (1) A matter requiring the decision of the Assembly shall be brought forward by means of a question put by the Chairman.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(", "attributes": {"background": "transparent"}}, {"insert": "2)"}, {"insert": " In all matters requiring to be decided by the members of the Assembly, the Chairman shall exercise a vote only in the case of an equality of votes.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) Votes may be taken by voices or division and shall be taken by division if any member so desires.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(5) The Chairman shall determine the method of taking vote by division.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(6) The result of a division shall be announced by the Chairman and shall not be challenged.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "31. (1) An amendment must be relevant to the motion to which it is proposed.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) An amendment may not be moved which has the effect of being the negative of the original motion.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) Except as permitted by the Chairman\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) notice of any amendment to a motion must be given at least one clear day before the motion is to be moved in the Assembly, and", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) notice of any amendment to an amendment must be given before the Assembly meets for the day on which the motion is to be moved.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) The Chairman may disallow any amendment which he considers to be frivolous or dilatory.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(5) The Chairman may put amendments to the vote in any order he may choose.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "32. No question which has once been decided by the Assembly shall be reopened except with the consent of at least one-fourth of the members present and voting.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "33. Any time after a motion has been made, any member may move ", "attributes": {"background": "transparent"}}, {"insert": "\u201c"}, {"insert": "that the question be now put\u201d and unless it appears to the Chairman that the motion is an infringement of the right of reasonable debate, the Chairman shall put the motion, ", "attributes": {"background": "transparent"}}, {"insert": "\u201c"}, {"insert": "that the question be now put\u201d; and if the motion is accepted, no further discussion on the original motion shall be permitted except for a reply by the member who made the original motion.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "34. In all matters relating to procedure or the conduct of business of the Assembly, the decision of the Chairman shall be final.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "35. It shall be the function of the Advisory Committee referred in paragraphs 19 and 20 of the Statement to initiate and consider proposals and to make a report to the Assembly upon fundamental rights, clauses for the protection of minorities and the administration of tribal and excluded areas; and the decisions of the Assembly upon such report shall be incorporated in the appropriate part of the Constitution.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "36. The Chairman of the Assembly after having called the attention of the Assembly to the conduct of a member, who persists in irrelevance or in tedious repetition, either of his own arguments or of the arguments used by other members in debate, may direct him to discontinue his speech, and the member shall, thereupon, resume his seat.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "37. (1) The Chairman shall preserve order and shall have all powers necessary for the purpose of enforcing his decisions on all points of order.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The Chairman may, in the case of grave disorder arising in the Assembly, suspend any sitting for a period not exceeding three days.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "38. (1) The admission of persons other than members to the Assembly Chamber and its galleries during the sittings of the Assembly shall be regulated in accordance with the orders of the Chairman:", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "Provided that when a meeting is held ", "attributes": {"background": "transparent"}}, {"insert": "in camera", "attributes": {"italic": true, "background": "transparent"}}, {"insert": " no persons other than members and the officers and staff on duty shall be admitted inside the Assembly Chamber or its galleries.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The meetings of the Assembly may, in the discretion of the Chairman, be held ", "attributes": {"background": "transparent"}}, {"insert": "in camera", "attributes": {"background": "transparent", "italic": true}}, {"insert": ".", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) The proceedings of all committees shall be conducted ", "attributes": {"background": "transparent"}}, {"insert": "in camera", "attributes": {"background": "transparent", "italic": true}}, {"insert": ".", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) The Secretary shall cause full reports of the proceedings of the Assembly to be printed and supplied to all members:", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "Provided that, where any meeting is held ", "attributes": {"background": "transparent"}}, {"insert": "in camera", "attributes": {"italic": true, "background": "transparent"}}, {"insert": ", such report shall be marked confidential and for the personal use of the members only.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(5) Where any meeting of the Assembly is held ", "attributes": {"background": "transparent"}}, {"insert": "in camera", "attributes": {"italic": true, "background": "transparent"}}, {"insert": ", the Chairman may authorise a summary of the proceedings to be issued to the press.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "C", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "HAPTER VII", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Committees.", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n"}, {"insert": "39. (1) A Steering Committee shall be set up for the duration of the Assembly and shall consist initially of eleven members (other than the President) to be elected by the Assembly in accordance with the principle of proportional representation by means of the single transferable vote.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The Assembly may from time to time elect, in such manner as it may deem appropriate, eight additional members, of whom four shall be reserved for election from among the representatives of the Indian States.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) The President shall be an ", "attributes": {"background": "transparent"}}, {"insert": "ex-officio", "attributes": {"background": "transparent", "italic": true}}, {"insert": " member of the Steering Committee and shall be its ", "attributes": {"background": "transparent"}}, {"insert": "ex-officio", "attributes": {"background": "transparent", "italic": true}}, {"insert": " Chairman. The Committee may elect a Vice-Chairman from among its members to preside over the Committee in the absence of the President.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) The Secretary of the Assembly shall be ", "attributes": {"background": "transparent"}}, {"insert": "ex-officio", "attributes": {"italic": true, "background": "transparent"}}, {"insert": " Secretary of the Steering Committee.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(5) Casual vacancies in the Committee shall be filled as soon as possible after they occur by election by the Assembly in such manner as it may determine.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "40. (1) The Committee shall\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) arrange the ord", "attributes": {"background": "transparent"}}, {"insert": "er ", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "of business for the day;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) group similar motions and amendments and secure, if possible, assent of the parties concerned to composite motions and amendments;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(c) act as a general liaison body between communities ", "attributes": {"background": "transparent"}}, {"insert": "inter se", "attributes": {"background": "transparent", "italic": true}}, {"insert": " and between the President and any part of the Assembly; and", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(d) deal with any other m", "attributes": {"background": "transparent"}}, {"insert": "a", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "tter under the rules or referred to it by the Assembly or the President.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The President may make standing orders for the conduct of the business of the Steering Committee.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "41. (1) A Staff and Finance Committee shall be set up for the duration of the Assembly and shall consist of\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) the President, who shall be ", "attributes": {"background": "transparent"}}, {"insert": "ex-officio ", "attributes": {"background": "transparent", "italic": true}}, {"insert": "Chairman of the Commit", "attributes": {"background": "transparent"}}, {"insert": "tee", "attributes": {"italic": null, "background": "transparent"}}, {"insert": ",", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) the two Vice-Presidents, and", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(c) nine other members to be elected by the Assembly in accordance with the principle of proportional presentation by means of the single transferable vote.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The Functions of the Committee shall be\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) to advise the President regarding the posts to be created in the Office of the Assembly, and the salaries and emoluments to be attached thereto;", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) to recommend to the Assembly the allowances to be paid to the officers and members of the Assembly and its committees; and", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(c) to frame a budget or supplementary budget for submission to the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) The President may make standing orders for the conduct of the business of the Committee.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) The Staff and Finance Committee shall invite the Auditor-General to audit the accounts of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "42. A Credentials Committee shall be set up for the duration of the Assembly for the purpose of dealing with all questions relating to the validity of the title of elected or other members.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "43. (1) The Committee shall consist of five members who shall be elected by the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The Committee shall have power to co-opt additional members not exceeding two in number.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) Casual vacancies in the Committee shall be filled as soon as they occur by election by the Assembly or by co-option, as the case may be.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(4) The Committee shall elect its own Chairman.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(5) The President may make standing orders for the conduct of the business of the Committee.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "44. (1) A House Committee shall be set up for the duration of the Assembly for the purpose of dealing with all questions relating to housing and accommodation of members, to provide for and to supervise over facilities for food, medical relief, entertainments, and reading room and library during their stay.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The Committee shall consist of eleven members, who shall be elected by the Assembly, in the manner to be prescribed by the President.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) The Committee shall have power to co-opt additional members and to appoint sub-committees to deal with various items of their work.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "45. (1) Any other committee may be set up by a motion in the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The members of every such committee shall, unless the motion by which the committee is set up otherwise provides, be elected according to the principle of proportional representation by means of the single transferable vote.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(3) Unless the motion by which a committee is set up otherwise provides, the committee shall appoint one of its members as Chairman who shall regulate the work of the committee.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "46. Subject to the provision of these rules, the Secretary of the Assembly, shall be ", "attributes": {"background": "transparent"}}, {"insert": "ex-officio", "attributes": {"background": "transparent", "italic": true}}, {"insert": " Secretary of every committee, unless the motion by which the committee is set up otherwise provides.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "47. The motion by which a committee is to be set up may state the quorum necessary to constitute a meeting of the committee and may fix the time within which the committee shall present its report, if any.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "48. The report of a committee shall be presented to the Assembly by the Chairman of the committee unless the committee otherwise provides, and a copy thereof shall be forwarded to the Office of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "C", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "HAPTER", "attributes": {"background": "transparent"}}, {"insert": " VIII", "attributes": {"italic": null, "background": "transparent"}}, {"insert": ".", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Budget.", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n", "attributes": {"align": null}}, {"insert": "49. (1) A statement of the estimated expenditure of the Assembly shall be prepared by the Staff and Finance Committee and placed before the Assembly for sanction.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) Supplementary statements may be similarly placed before the Assembly in accordance with the directions of the President.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "C", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "HAPTER", "attributes": {"background": "transparent"}}, {"insert": " IX", "attributes": {"italic": null, "background": "transparent"}}, {"insert": ".", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Salaries and Allowances.", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n", "attributes": {"align": null}}, {"insert": "50. (1) Allowances of the members shall be fixed by the Assembly on a motion approved by the Staff and Finance Committee. The Committee may make standing orders providing for special allowances to members in particular cases as well as for allowances to non-members engaged in the work of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The salaries and allowances of the servants of the Government of India or any Provincial Government or any other authority whose services are placed at the disposal of the Assembly shall be such as may be agreed upon between the Government or other authority concerned and the President acting on the advice of the Staff and Finance Committee. The Salaries and allowances of all persons recruited directly shall be such as may be fixed by the President on the advice of the Staff and Finance Committee.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "C", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "HAPTER", "attributes": {"background": "transparent"}}, {"insert": " X", "attributes": {"italic": null, "background": "transparent"}}, {"insert": ".", "attributes": {"background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Doubts and Disputes as to Elections.", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n", "attributes": {"align": null}}, {"insert": "51. In this Chapter, unless there is anything repugnant in the subject or context,\u2014", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) ", "attributes": {"background": "transparent"}}, {"insert": "\u201c"}, {"insert": "Candidate\u201d means a person who has been nominated as a candidate at any election or who claims that he has been so nominated or that his nomination has been improperly refused\u2019", "attributes": {"background": "transparent"}}, {"insert": "\n\n(aa) \u2018representative\u2019 of any Indian State or States means the person who is chosen as a representative of such State or States in the Assembly in accordance with the provisions contained in the Schedule to these Rules.\n\n"}, {"insert": "(b) ", "attributes": {"background": "transparent"}}, {"insert": "\u201c"}, {"insert": "Returned Candidate\u201d means a candidate whose name has been published in the appropriate Official Gazette as a duly elected member of the Assembly ", "attributes": {"background": "transparent"}}, {"insert": "and includes a candidate whose name has been reported by or on behalf of the Ruler or Rulers of any Indian State or States to the President in the manner provided in the Schedule to these rules as a duly chosen representative of such State or States"}, {"insert": ".", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "52. No election shall be called in question except by an election petition presented in accordance with the provisions of this Chapter.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "53. (1) An election petition against any returned candidate may be presented to the President by any candidate or elector on the ground of any irregularity or corrupt practice:.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(i) ", "attributes": {"background": "transparent"}}, {"insert": "in the case of election to the Assembly", "attributes": {"background": null}}, {"insert": " held before the publication of these Rules"}, {"insert": ", within fifteen days from the date on which these rules are published in the ", "attributes": {"background": "transparent"}}, {"insert": "Gazette of India", "attributes": {"italic": null, "background": "transparent"}}, {"insert": ";", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(ii) in the case of subsequent elections within thirty days from the date on which the results of the elections are published ", "attributes": {"background": "transparent"}}, {"insert": "in the ", "attributes": {"background": null}}, {"insert": "Gazette of Ind"}, {"insert": "ia", "attributes": {"background": null}}, {"insert": " or in "}, {"insert": "t", "attributes": {"background": null}}, {"insert": "h"}, {"insert": "e Official Gazette", "attributes": {"background": null}}, {"insert": " of the Province concerned"}, {"insert": ".", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) An election petition shall be deemed to have been presented to the President when it is delivered to the President or to any officers appointed by him in this behalf:", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(a) by a person making the petition; or", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(b) by a person authorised in writing in this behalf by the person making the petition; or", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(c) by registered post.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "54. At the time of the presentation of the petition, or, in the case of any petition presented before the date on which these rules come into force, within fifteen days from the date on which these rules are published in the ", "attributes": {"background": "transparent"}}, {"insert": "Gazette of India", "attributes": {"italic": null, "background": "transparent"}}, {"insert": ", the practitioner shall deposit the sum of rupees one thousand in cash or in Government promissory notes of equal value at the market rate of the day as security for the costs of the case.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "55. (1) If the provisions of rule 54 or rule 55 are not complied with, the President shall dismiss the petition:", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "Provided that if the person making the petition satisfies the President that sufficient cause existed for his not presenting the petition within the period described in rule 54, the President shall have discretion to condone the failure to comply with that rule.", "attributes": {"background": "transparent"}}, {"insert": "\n"}, {"insert": "(2) If the petition is not dismissed under the preceding sub-rule, the President shall, if he is satisfied that sufficient grounds exist for such action, refer the petition to the Credentials Committee.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "56. The Credentials Committee shall, with due despatch, inquire into the allegations made in the petition and, subject to the provisions of the next succeeding rule, submit a report to the President.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "57. The Credentials Committee may, if they think fit, recommend to the President that an election tribunal be appointed to inquire into the petition.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "58. Where such a recommendation has been made, the President shall appoint an election tribunal consisting of one or more than one person to inquire into the petition. ", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "59. On the conclusion of the inquiry, the election tribunal shall make a report to the President.", "attributes": {"background": "transparent"}}, {"insert": "\n\n59-A. (1) The Credentials Committee or the Election Tribunal shall, for the purposes of an inquiry into an election petition, have power to summon and enforce the attendance of witnesses and to compel the production of documents by the same means and, so far as may be, in the same manner as is provided in the case of a civil court under the Code of Civil Procedure, 1908 (V of 1908).\n\n(2) The provisions of the Indian Evidence Act, 1872, shall, subject to the provisions of these rules and the Standing Orders made by the President, be deemed to apply to every such inquiry.\n\n"}, {"insert": "60. (1) If in the opinion of the Credentials Committee or of the election tribunal, as the case may be, the election of the returned candidate has been vitiated by a corrupt practice of the kind specified in the Indian Legislative Assembly Electoral Rules ", "attributes": {"background": "transparent"}}, {"insert": "as in force on the 1st day of August, 1947 "}, {"insert": "or has been materially affected by the improper acceptance or refusal of any nomination or by the improper reception or refusal of a vote or the reception of any vote which is void, or if the election has not been a free election by reason of the large number of cases in which undue influence or bribery of the kind described in the aforesaid Legislative Assembly Electoral Rules has been exercised or committed, the Committee or the tribunal, as the case may be may recommend in the report that the election be declared void.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "(2) The report of the Credentials Committee, or the election tribunal, as the case may be, shall include a recommendation as to the total amount of costs which are payable and the persons by and to whom such costs should be paid out of the sum deposited as security under rule 55 and whether the said sum should be returned.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "61. On receipt of the report of the Credentials Committee or the election tribunal, as the case may be, the President shall issue orders in accordance therewith ", "attributes": {"background": "transparent"}}, {"insert": "and the orders so issued shall be final and shall not be questioned in any court"}, {"insert": ".", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "C", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "HAPTER", "attributes": {"background": "transparent"}}, {"insert": " XII", "attributes": {"italic": null, "background": "transparent"}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Miscellaneous", "attributes": {"background": "transparent", "italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n", "attributes": {"align": null}}, {"insert": "62. All elections in the Assembly to be held on the principle of proportional representation by means of the single transferable vote shall be conducted ", "attributes": {"background": "transparent"}}, {"insert": "mutatis mutandis", "attributes": {"italic": true, "background": "transparent"}}, {"insert": " in accordance with the regulations in force in this behalf in the Indian Legislative Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "63. Subject to the requirement of a quorum prescribed by or under these rules, the Assembly and any committee set up by the Assembly shall have power to act notwithstanding any vacancy in the membership thereof.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "64. No new rule shall be made nor shall any of these rules be amended or deleted except after a reference of the proposal so to make, amend, or delete the rule to the Steering Committee, which shall report to the Assembly within two weeks of the receipt of the reference.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "65. Save as otherwise provided in these rules, the provisions thereof shall apply ", "attributes": {"background": "transparent"}}, {"insert": "mutatis mutandis", "attributes": {"italic": true, "background": "transparent"}}, {"insert": " to the Committees of the Assembly.", "attributes": {"background": "transparent"}}, {"insert": "\n\n"}, {"insert": "66. Where, in the opinion of the President, any difficulty arises in the carrying out of these rules, or in respect of any matter for which no provision is made in these rules, the President may, notwithstanding anything contained therein, make such provision as he thinks fit for the purpose of removing the difficulty.", "attributes": {"background": "transparent"}}, {"insert": "\n\n67. If any question arises as to the interpretation of these rules otherwise than in connection with an election held thereunder, the question shall be referred for the decision of the President and his decision shall be final.\n\nTHE SCHEDULE "}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "(See Rule 51) "}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n1. The seats allotted to Indian States in the Statement shall be allocated among the various States and groups of States as in Annexure A, generally on the basis of one seat for one million of the population, fractions of three-fourths or more being counted as one and lesser fraction being ignored in the case of individual States, and fractions of more than half being counted as one and lesser fractions being ignored in the case of groups of States.\n\n2. The President may, on the application of any State or States concerned, by order amend Annexure A to this Schedule so as to\u2014\n\n(a) alter the representation allotted to the States, individual or grouped;\n\n(b) alter the grouping of the States by the division of a group into more than one group or the transfer of any State, or States from one group to another or otherwise; \n\nProvided that\u2014 \n\n(i) no such alteration shall affect the total representation of all States or of the group or groups of States concerned; and \n\n(ii) in making any such alteration the population basis shall not be departed from and the geographical proximity, economic considerations, and ethnic, cultural and linguistic affinity shall be duly kept in view.\n\n2-A. When the representation allotted to the States, individual or grouped, or the grouping of the States is altered by an order made under paragraph 2, the President may, on application made in that behalf by the States affected by such order, declare the seats of the members of the Assembly representing the States so affected to be vacant.\n\n3. Not less than 50 per cent of the total representatives of the States in the Assembly shall be elected by the elected members of the States\u2019 legislatures, or where, such legislatures do not exist, by the members of electoral colleges constituted in accordance with the provisions made in this behalf by the Rulers of the States concerned. The States shall endeavour to increase the quota of elected representatives as much above 50 per cent of the total number as possible. Accordingly at least one half of the number of seats allotted to any State or group of States shall be filled by election in accordance with the provision made in that behalf by the Ruler of the State or States concerned. \n\n4. The Conveners, in respect of the various groups of States specified in column 1 of the Annexure A, shall be the rulers specified in the corresponding entries in column 4 of that Annexure. The Secretary may in consultation with the States in the group make any such changes in the said column 4 as he may deem necessary or desirable. \n\n5. On the completion of the election or nomination, as the case may be, the Ruler of the State concerned shall make a notification as far as may be in the following form stating the name or names of the person or persons elected or nominated as representative or representatives in the Constituent Assembly and cause it to be communicated to the President of the Constituent Assembly. Where the selection has been made by a group of States, this notification shall be made by the convener for that group.\n\nFORM "}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "BE IT HEREBY KNOWN THAT [here enter the name of the representative(s)] _____ has/have been duly chosen as (a) representative(s) of [here, enter the name(s) of the State(s)] _____ in the Constituent Assembly of India. In testimony whereof this notification is issued under my signature and the Seal of my State. \nState(s) __________\nDate __________\nRuler of __________"}, {"insert": "\n", "attributes": {"align": "right"}}, {"insert": "ANNEXURE A"}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "Single State", "attributes": {"italic": true}}, {"insert": "\n", "attributes": {"align": "center"}}, {"insert": "\n"}, {"insert": "\n\n\n\n", "attributes": {"table-col": {"width": "100"}}}, {"insert": "Division as shown in the Table of Seats appended to Part II of the First Schedule to the Govt. of India Act, 1935."}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-xemd", "cell": "cell-m7ns"}, "row": "row-xemd", "rowspan": "1", "colspan": "1"}}, {"insert": "Name of State"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-xemd", "cell": "cell-v0w3"}, "row": "row-xemd", "rowspan": "1", "colspan": "1"}}, {"insert": "Number of seats in the Constituent Assembly"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-xemd", "cell": "cell-gu75"}, "row": "row-xemd", "rowspan": "1", "colspan": "1"}}, {"insert": "Convener"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-xemd", "cell": "cell-70dh"}, "row": "row-xemd", "rowspan": "1", "colspan": "1"}}, {"insert": "1"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-7r4w", "cell": "cell-hg6q"}, "row": "row-7r4w", "rowspan": "1", "colspan": "1"}}, {"insert": "2"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-7r4w", "cell": "cell-ha75"}, "row": "row-7r4w", "rowspan": "1", "colspan": "1"}}, {"insert": "3"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-7r4w", "cell": "cell-9ljk"}, "row": "row-7r4w", "rowspan": "1", "colspan": "1"}}, {"insert": "4"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-7r4w", "cell": "cell-dgun"}, "row": "row-7r4w", "rowspan": "1", "colspan": "1"}}, {"insert": "I"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-c150", "cell": "cell-eilq"}, "row": "row-c150", "rowspan": "1", "colspan": "1"}}, {"insert": "Hyderabad"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-c150", "cell": "cell-rz42"}, "row": "row-c150", "rowspan": "1", "colspan": "1"}}, {"insert": "16"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-c150", "cell": "cell-eufp"}, "row": "row-c150", "rowspan": "1", "colspan": "1"}}, {"insert": ".."}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-c150", "cell": "cell-ot69"}, "row": "row-c150", "rowspan": "1", "colspan": "1"}}, {"insert": "II"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-kn4x", "cell": "cell-6gwi"}, "row": "row-kn4x", "rowspan": "1", "colspan": "1"}}, {"insert": "Mysore"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-kn4x", "cell": "cell-y7oi"}, "row": "row-kn4x", "rowspan": "1", "colspan": "1"}}, {"insert": "7"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-kn4x", "cell": "cell-qlbm"}, "row": "row-kn4x", "rowspan": "1", "colspan": "1"}}, {"insert": ".."}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-kn4x", "cell": "cell-9ohf"}, "row": "row-kn4x", "rowspan": "1", "colspan": "1"}}, {"insert": "III"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-jbad", "cell": "cell-xzdp"}, "row": "row-jbad", "rowspan": "1", "colspan": "1"}}, {"insert": "Kashmir"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-jbad", "cell": "cell-fixa"}, "row": "row-jbad", "rowspan": "1", "colspan": "1"}}, {"insert": "4"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-jbad", "cell": "cell-px7n"}, "row": "row-jbad", "rowspan": "1", "colspan": "1"}}, {"insert": ".."}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-jbad", "cell": "cell-j2pw"}, "row": "row-jbad", "rowspan": "1", "colspan": "1"}}, {"insert": "IV"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-k35j", "cell": "cell-0dg8"}, "row": "row-k35j", "rowspan": "1", "colspan": "1"}}, {"insert": "Gwalior"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-k35j", "cell": "cell-1tzu"}, "row": "row-k35j", "rowspan": "1", "colspan": "1"}}, {"insert": "4"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-k35j", "cell": "cell-1t6z"}, "row": "row-k35j", "rowspan": "1", "colspan": "1"}}, {"insert": ".."}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-k35j", "cell": "cell-4elt"}, "row": "row-k35j", "rowspan": "1", "colspan": "1"}}, {"insert": "V"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-00x6", "cell": "cell-ea5x"}, "row": "row-00x6", "rowspan": "1", "colspan": "1"}}, {"insert": "Baroda"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-00x6", "cell": "cell-ccg5"}, "row": "row-00x6", "rowspan": "1", "colspan": "1"}}, {"insert": "3"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-00x6", "cell": "cell-egcx"}, "row": "row-00x6", "rowspan": "1", "colspan": "1"}}, {"insert": ".."}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-00x6", "cell": "cell-d46k"}, "row": "row-00x6", "rowspan": "1", "colspan": "1"}}, {"insert": "IX"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-ln5o", "cell": "cell-6fxj"}, "row": "row-ln5o", "rowspan": "1", "colspan": "1"}}, {"insert": "Travancore"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-ln5o", "cell": "cell-o68b"}, "row": "row-ln5o", "rowspan": "1", "colspan": "1"}}, {"insert": "6"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-ln5o", "cell": "cell-3jyz"}, "row": "row-ln5o", "rowspan": "1", "colspan": "1"}}, {"insert": ".."}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-ln5o", "cell": "cell-38u8"}, "row": "row-ln5o", "rowspan": "1", "colspan": "1"}}, {"insert": "IX"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-9pxi", "cell": "cell-ubqp"}, "row": "row-9pxi", "rowspan": "1", "colspan": "1"}}, {"insert": "Cochin"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-9pxi", "cell": "cell-p387"}, "row": "row-9pxi", "rowspan": "1", "colspan": "1"}}, {"insert": "1"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-9pxi", "cell": "cell-866c"}, "row": "row-9pxi", "rowspan": "1", "colspan": "1"}}, {"insert": ".."}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-9pxi", "cell": "cell-v341"}, "row": "row-9pxi", "rowspan": "1", "colspan": "1"}}, {"insert": "X"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-8k6e", "cell": "cell-tdd9"}, "row": "row-8k6e", "rowspan": "1", "colspan": "1"}}, {"insert": "Udaipur"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-8k6e", "cell": "cell-dkni"}, "row": "row-8k6e", "rowspan": "1", "colspan": "1"}}, {"insert": "2"}, {"insert": "\n", "attributes": {"table-cell-line": {"rowspan": "1", "colspan": "1", "row": "row-8k6e", "cell": "cell-uehr"}, "row": "row-8k6e", "rowspan": "1", "colspan": "1"}}, {"insert": ".."}, {"insert": "\n", "a